<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Admin</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
<div class="card">
<div class="topbar">
<h1 class="brand">Panel Admin</h1>
<a href="/logout" class="btn">Salir</a>
</div>

<form method="POST" action="/nota">
<select name="usuario_id" required>
<% users.forEach(u => { if(u.rol === 'estudiante'){ %>
<option value="<%= u.id %>"><%= u.nombre %></option>
<% } }) %>
</select>

<input type="text" name="materia" placeholder="Materia" required>
<input type="number" step="0.1" name="nota" placeholder="Nota" required>
<textarea name="observacion" placeholder="Observación"></textarea>
<button type="submit">Guardar Nota</button>
</form>

<table class="table">
<tr>
<th>Estudiante</th>
<th>Materia</th>
<th>Nota</th>
<th>Observación</th>
</tr>

<% notas.forEach(n => { %>
<tr>
<td><%= n.nombre %></td>
<td><%= n.materia %></td>
<td><%= n.nota %></td>
<td><%= n.observacion %></td>
</tr>
<% }) %>
</table>

</div>
</div>
</body>
</html>